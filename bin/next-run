#!/bin/sh

FALLBACK_NODE="$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node"

if [ -n "$RM_REFRESHER_NODE" ] && [ -x "$RM_REFRESHER_NODE" ]; then
  NODE_BIN="$RM_REFRESHER_NODE"
elif [ -x "$FALLBACK_NODE" ]; then
  NODE_BIN="$FALLBACK_NODE"
elif command -v node >/dev/null 2>&1; then
  NODE_BIN="$(command -v node)"
else
  echo "No Node.js runtime found for Next.js." >&2
  exit 1
fi

exec "$NODE_BIN" "$PWD/node_modules/next/dist/bin/next" "$@"
